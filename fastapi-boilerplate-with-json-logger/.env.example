# FastAPI settings
TITLE="Boilerplate API"
DESCRIPTION="Starter FastAPI application."
DEBUG="1"
VERSION="0.0.1"
DOCS_URL="/api/schema/docs"
REDOC_URL="/api/schema/redoc"
OPENAPI_URL="/api/schema/openapi.json"

# Logging settings
LOG_FORMAT="%(levelname)s %(asctime)s %(name)s %(message)s %(pathname)s %(lineno)d"
LOG_DATEFMT="%Y-%m-%d %H:%M:%S"

# Uvicorn settings
UVICORN_LOOP="uvloop"
